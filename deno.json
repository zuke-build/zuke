{
  "workspace": [
    "packages/core",
    "packages/cmd",
    "packages/deno",
    "packages/docs",
    "packages/npm",
    "packages/bun",
    "packages/pnpm",
    "packages/yarn",
    "packages/cli",
    "packages/docker",
    "packages/docker-compose",
    "packages/kubectl",
    "packages/helm",
    "packages/kustomize",
    "packages/oxlint",
    "packages/eslint",
    "packages/cspell",
    "packages/jest",
    "packages/vitest",
    "packages/playwright",
    "packages/cypress",
    "packages/biome",
    "packages/knip",
    "packages/dpdm",
    "packages/jsr",
    "packages/vite",
    "packages/tsup",
    "packages/turbo",
    "packages/nx",
    "packages/tsx",
    "packages/tsgo",
    "packages/dprint",
    "packages/gcloud",
    "packages/git",
    "packages/gh",
    "packages/claude",
    "packages/codex",
    "packages/gemini",
    "packages/terraform",
    "packages/tofu",
    "packages/release-please",
    "packages/security",
    "packages/ai"
  ],
  "tasks": {
    "zuke": "deno run -A zuke.ts",
    "test": "GITHUB_STEP_SUMMARY= deno test -A --frozen",
    "cov": "deno run -A zuke.ts coverage",
    "cov:report": "deno coverage cov_profile '--exclude=tests/'",
    "check": "deno check --frozen zuke.ts tests/*.ts packages/*/mod.ts packages/*/src/*.ts packages/*/tests/*.ts",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "lint": "deno lint",
    "spell": "deno run --allow-read --allow-env --allow-sys npm:cspell@9 lint --no-progress '**'",
    "ci": "deno fmt --check && deno lint && deno task spell && deno task check && deno task cov"
  },
  "fmt": {
    "include": [
      "zuke.ts",
      "tests/",
      "packages/"
    ],
    "exclude": [
      "packages/*/CHANGELOG.md"
    ]
  },
  "lint": {
    "include": [
      "zuke.ts",
      "tests/",
      "packages/"
    ],
    "rules": {
      "tags": [
        "recommended"
      ],
      "include": [
        "no-explicit-any",
        "verbatim-module-syntax",
        "ban-untagged-todo"
      ]
    }
  }
}
