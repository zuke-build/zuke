{
  "workspace": [
    "packages/core",
    "packages/cmd",
    "packages/deno",
    "packages/npm",
    "packages/cli",
    "packages/docker",
    "packages/docker-compose",
    "packages/oxlint",
    "packages/eslint",
    "packages/cspell",
    "packages/jest",
    "packages/vitest",
    "packages/security"
  ],
  "tasks": {
    "zuke": "deno run -A zuke.ts",
    "test": "deno test -A --frozen",
    "cov": "deno test -A --frozen --coverage=cov_profile && deno coverage cov_profile --lcov '--exclude=(tests|scripts)/' --output=cov.lcov && deno run --allow-read scripts/check-coverage.ts cov.lcov 95",
    "cov:report": "deno coverage cov_profile '--exclude=(tests|scripts)/'",
    "check": "deno check --frozen zuke.ts scripts/*.ts tests/*.ts packages/*/mod.ts packages/*/src/*.ts packages/*/tests/*.ts",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "lint": "deno lint",
    "spell": "deno run --allow-read --allow-env --allow-sys npm:cspell@9 lint --no-progress '**'",
    "ci": "deno fmt --check && deno lint && deno task spell && deno task check && deno task cov"
  },
  "fmt": {
    "include": [
      "zuke.ts",
      "scripts/",
      "tests/",
      "packages/"
    ],
    "exclude": [
      "packages/*/CHANGELOG.md"
    ]
  },
  "lint": {
    "include": [
      "zuke.ts",
      "scripts/",
      "tests/",
      "packages/"
    ],
    "rules": {
      "tags": [
        "recommended"
      ],
      "include": [
        "no-explicit-any",
        "verbatim-module-syntax",
        "ban-untagged-todo"
      ]
    }
  }
}
