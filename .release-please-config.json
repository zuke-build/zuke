{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "deno",
  "tag-separator": "-v",
  "separate-pull-requests": true,
  "packages": {
    "packages/core": {
      "component": "core",
      "changelog-path": "CHANGELOG.md"
    },
    "packages/deno": {
      "component": "deno",
      "changelog-path": "CHANGELOG.md"
    },
    "packages/npm": {
      "component": "npm",
      "changelog-path": "CHANGELOG.md"
    },
    "packages/cmd": {
      "component": "cmd",
      "changelog-path": "CHANGELOG.md"
    }
  }
}
