{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "simple",
  "tag-separator": "-",
  "separate-pull-requests": false,
  "bump-minor-pre-major": true,
  "packages": {
    "packages/core": {
      "component": "core",
      "changelog-path": "CHANGELOG.md",
      "release-as": "0.1.0",
      "extra-files": [
        { "type": "json", "path": "deno.json", "jsonpath": "$.version" }
      ]
    },
    "packages/deno": {
      "component": "deno",
      "changelog-path": "CHANGELOG.md",
      "release-as": "0.1.0",
      "extra-files": [
        { "type": "json", "path": "deno.json", "jsonpath": "$.version" }
      ]
    },
    "packages/npm": {
      "component": "npm",
      "changelog-path": "CHANGELOG.md",
      "release-as": "0.1.0",
      "extra-files": [
        { "type": "json", "path": "deno.json", "jsonpath": "$.version" }
      ]
    },
    "packages/cmd": {
      "component": "cmd",
      "changelog-path": "CHANGELOG.md",
      "release-as": "0.1.0",
      "extra-files": [
        { "type": "json", "path": "deno.json", "jsonpath": "$.version" }
      ]
    },
    "packages/cli": {
      "component": "cli",
      "changelog-path": "CHANGELOG.md",
      "release-as": "0.1.0",
      "extra-files": [
        { "type": "json", "path": "deno.json", "jsonpath": "$.version" },
        "src/version.ts"
      ]
    }
  }
}
